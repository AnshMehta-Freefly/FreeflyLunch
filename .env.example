# Example secrets file. Copy these keys into /etc/freefly-lunch.env on the server
# (root-owned, chmod 600). Do NOT put real values here - this file is committed
# to the public repo. The real /etc/freefly-lunch.env is gitignored and stays local.

# Enables "Read receipt with AI". Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Optional: public HTTPS base URL, only if you ever expose the server via a tunnel.
# PUBLIC_BASE_URL=https://your-host.example
